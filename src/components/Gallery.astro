---
import fs from 'node:fs';
import path from 'node:path';

const imagesDir = path.join(process.cwd(), 'public', 'imagenes');
let files = [];

try {
  files = fs.readdirSync(imagesDir);
} catch (e) {
  console.error("Error reading images directory", e);
}

const images = files.filter(file => file.endsWith('.jpeg') || file.endsWith('.jpg') || file.endsWith('.png'));
const videos = files.filter(file => file.endsWith('.mp4'));
---

<section class="gallery" id="galeria" aria-labelledby="gallery-title">
  <div class="container">
    <div class="gallery__header" data-animate>
      <span class="section-tag">Galería</span>
      <h2 class="section-title" id="gallery-title">Nuestros <em>Trabajos</em></h2>
      <p class="section-subtitle">Explora algunos de nuestros proyectos recientes en fabricación e instalación de puertas a medida con los más altos estándares.</p>
    </div>

    <div class="gallery__grid">
      {images.map((img, i) => (
        <div class="gallery__item" data-animate style={`animation-delay: ${(i % 4) * 0.1}s`}>
          <img src={`/imagenes/${img}`} alt="Trabajo Puertas Valencia" loading="lazy" />
          <div class="gallery__overlay">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    {videos.length > 0 && (
      <div class="gallery__videos">
        <h3 class="videos-title" data-animate>Videos de <em>Instalaciones</em></h3>
        <div class="videos-carousel" data-animate>
          <button class="carousel-btn prev" aria-label="Anteriores">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          
          <div class="videos-track-wrap">
            <div class="videos-track">
              {videos.map((vid, i) => (
                <div class="video-card" data-video-src={`/imagenes/${vid}`}>
                  <video src={`/imagenes/${vid}#t=3.0`} preload="metadata" muted playsinline></video>
                  <div class="video-overlay">
                    <div class="play-btn">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
          <button class="carousel-btn next" aria-label="Siguientes">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
    )}

    <!-- Lightbox Modal -->
    <div id="lightbox" class="lightbox" aria-hidden="true">
      <div class="lightbox__overlay"></div>
      <button class="lightbox__close" aria-label="Cerrar">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="lightbox__content">
        <img id="lightbox-img" src="" alt="Imagen ampliada" style="display: none;" />
        <video id="lightbox-video" src="" controls playsinline style="display: none;"></video>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Variables de paleta ──────────────────────────────── */
  :root {
    --g-gold:        #c8a84b;
    --g-gold-light:  #e8c96a;
    --g-gold-dark:   #96791f;
    --g-metal-dark:  #111111;
  }

  /* ── Sección ────────────────────────────────────────── */
  .gallery {
    padding: 72px 0;
    background: #f5f4f0; /* Tono cálido premium */
    position: relative;
  }

  /* Franja metálica superior */
  .gallery::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #1a1a1a 0%, #888 40%, #c8c8c8 55%, #888 70%, #1a1a1a 100%);
  }

  /* ── Encabezado ─────────────────────────────────────── */
  .gallery__header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 56px;
  }

  .section-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--g-gold-dark);
    border: 1.5px solid var(--g-gold);
    padding: 5px 16px;
    border-radius: 2px;
    margin-bottom: 18px;
    background: rgba(200,168,75,0.05);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1;
    text-transform: uppercase;
    color: var(--g-metal-dark);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .section-title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--g-gold-dark) 0%, var(--g-gold) 45%, var(--g-gold-light) 60%, var(--g-gold) 80%, var(--g-gold-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    color: #666;
    font-size: 16px;
    line-height: 1.7;
  }

  /* ── Grid de Galería ────────────────────────────────── */
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 48px;
  }

  .gallery__item {
    border-radius: 8px;
    overflow: hidden;
    background: #e5e5e5;
    aspect-ratio: 4/5;
    position: relative;
    border: 1px solid rgba(200,168,75,0.15);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    cursor: pointer;
  }

  /* Efecto Hover en las cards */
  .gallery__item::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid transparent;
    border-radius: 8px;
    z-index: 3;
    transition: border-color 0.4s ease;
    pointer-events: none;
  }

  .gallery__item:hover {
    box-shadow: 0 12px 36px rgba(0,0,0,0.15);
  }

  .gallery__item:hover::before {
    border-color: var(--g-gold);
  }

  .gallery__item img,
  .gallery__item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .gallery__item:hover img {
    transform: scale(1.08);
  }

  /* Overlay Oscuro con Icono Dorado */
  .gallery__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,17,17,0.8) 0%, rgba(17,17,17,0.2) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 2;
  }

  .gallery__overlay svg {
    color: var(--g-gold-light);
    width: 32px;
    height: 32px;
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
  }

  .gallery__item:hover .gallery__overlay {
    opacity: 1;
  }

  .gallery__item:hover .gallery__overlay svg {
    transform: translateY(0);
  }

  /* ── Videos (Carrusel Premium) ──────────────────────── */
  .gallery__videos {
    margin-top: 64px;
    border-top: 1px solid rgba(200,168,75,0.3);
    padding-top: 56px;
    position: relative;
  }

  .gallery__videos::before {
    content: '◆';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--g-gold);
    font-size: 14px;
    background: #f5f4f0;
    padding: 0 16px;
  }

  .videos-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 4vw, 36px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--g-metal-dark);
    text-align: center;
    margin-bottom: 40px;
  }

  .videos-title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--g-gold-dark) 0%, var(--g-gold) 45%, var(--g-gold-light) 60%, var(--g-gold) 80%, var(--g-gold-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Carrusel Contenedor */
  .videos-carousel {
    position: relative;
    max-width: 100%;
    /* Espacio a los lados para las flechas en desktop */
    padding: 0 48px;
  }

  /* Flechas de Navegación */
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #111 0%, #2a2a2a 100%);
    border: 1px solid rgba(200,168,75,0.4);
    color: var(--g-gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    transition: all 0.3s ease;
  }
  
  .carousel-btn:hover {
    background: linear-gradient(135deg, var(--g-gold-dark) 0%, var(--g-gold) 50%, var(--g-gold-light) 100%);
    color: #111;
    border-color: var(--g-gold-light);
    transform: translateY(-50%) scale(1.1);
  }

  .carousel-btn.prev { left: -10px; }
  .carousel-btn.next { right: -10px; }

  .videos-track-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 24px;
    scroll-behavior: smooth; /* Desplazamiento suave nativo */
  }
  .videos-track-wrap::-webkit-scrollbar { display: none; }

  .videos-track {
    display: flex;
    gap: 20px;
    /* Ajusta el ancho para forzar scroll si hay muchos videos */
    width: max-content;
    padding: 0 4px;
  }

  .video-card {
    width: 280px;
    aspect-ratio: 9/16;
    background: #111;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(200,168,75,0.2);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    cursor: pointer;
    transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
  }

  .video-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.18);
    border-color: var(--g-gold);
  }

  .video-card video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none; /* Que no se pueda interactuar con los controles nativos */
  }

  /* Capa de overlay con botón Play */
  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,17,17,0.7) 0%, rgba(17,17,17,0.1) 50%, rgba(17,17,17,0.4) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .video-card:hover .video-overlay {
    background: rgba(17,17,17,0.4);
  }

  .play-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--g-gold-dark) 0%, var(--g-gold) 50%, var(--g-gold-light) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    box-shadow: 0 4px 16px rgba(200,168,75,0.4), inset 0 1px 0 rgba(255,255,255,0.5);
    transition: transform 0.3s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .video-card:hover .play-btn {
    transform: scale(1.15);
  }

  .play-btn svg {
    margin-left: 4px; /* Centrado visual óptico del botón play */
  }

  /* ── Lightbox Modal ─────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(8px);
    cursor: pointer;
  }

  .lightbox__close {
    position: absolute;
    top: 24px;
    right: 32px;
    background: transparent;
    border: none;
    color: var(--g-gold);
    cursor: pointer;
    z-index: 2;
    padding: 8px;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .lightbox__close:hover {
    transform: scale(1.1) rotate(90deg);
    color: var(--g-gold-light);
  }

  .lightbox__content {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 85vh;
    border-radius: 4px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.5);
    border: 1px solid rgba(200,168,75,0.3);
    overflow: hidden;
    transform: scale(0.95);
    transition: transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .lightbox.is-open .lightbox__content {
    transform: scale(1);
  }

  .lightbox__content img,
  .lightbox__content video {
    display: block;
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    background: #0a0a0a;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .videos-carousel { padding: 0; }
    .carousel-btn { display: none; } /* En móvil y tablet se usa el dedo (touch scroll) */
  }

  @media (max-width: 600px) {
    .gallery { padding: 56px 0; }
    .gallery__header { margin-bottom: 40px; }
    .gallery__grid { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
    .video-card { width: 240px; }
    .lightbox__close { top: 16px; right: 16px; }
    .lightbox__content { max-width: 95vw; max-height: 80vh; }
    .lightbox__content img, .lightbox__content video { max-height: 80vh; }
  }
</style>

<script>
  // Script para el Lightbox (Imágenes y Videos)
  const galleryItems = document.querySelectorAll('.gallery__item');
  const videoCards = document.querySelectorAll('.video-card');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxVideo = document.getElementById('lightbox-video') as HTMLVideoElement;
  const lightboxClose = document.querySelector('.lightbox__close');
  const lightboxOverlay = document.querySelector('.lightbox__overlay');

  if (lightbox) {
    // Abrir imágenes
    galleryItems.forEach(item => {
      item.addEventListener('click', () => {
        const img = item.querySelector('img');
        if (img) {
          lightboxImg.src = img.src;
          lightboxImg.style.display = 'block';
          lightboxVideo.style.display = 'none';
          
          lightbox.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Abrir videos
    videoCards.forEach(card => {
      card.addEventListener('click', () => {
        const videoSrc = card.getAttribute('data-video-src');
        if (videoSrc) {
          lightboxVideo.src = videoSrc;
          lightboxVideo.style.display = 'block';
          lightboxImg.style.display = 'none';
          
          lightbox.classList.add('is-open');
          document.body.style.overflow = 'hidden';
          lightboxVideo.play();
        }
      });
    });

    // Función para cerrar
    const closeLightbox = () => {
      lightbox.classList.remove('is-open');
      document.body.style.overflow = '';
      
      // Pausar el video inmediatamente si está sonando
      if(lightboxVideo) lightboxVideo.pause();

      setTimeout(() => { 
        if(lightboxImg) lightboxImg.src = ''; 
        if(lightboxVideo) {
          lightboxVideo.src = '';
        }
      }, 300); // Limpiar después de transición
    };

    // Eventos de cierre
    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxOverlay?.addEventListener('click', closeLightbox);
    
    // Cerrar con tecla Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('is-open')) {
        closeLightbox();
      }
    });
  }

  // Script para flechas del carrusel de videos
  const trackWrap = document.querySelector('.videos-track-wrap');
  const prevBtn = document.querySelector('.carousel-btn.prev');
  const nextBtn = document.querySelector('.carousel-btn.next');

  if (trackWrap && prevBtn && nextBtn) {
    const scrollAmount = 320; // Ancho de tarjeta + gap aprox
    prevBtn.addEventListener('click', () => {
      trackWrap.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      trackWrap.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }
</script>
