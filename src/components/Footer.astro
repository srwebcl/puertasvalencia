---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__main">
    <div class="container footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <div class="footer__logo">
          <img src="/web_images/Logo-Puertas-Valencia-B.webp" alt="Puertas Valencia Logo" style="height: 56px; width: auto; object-fit: contain;" />
        </div>
        <p class="footer__desc">
          Fabricamos puertas enchapadas en madera y puertas de seguridad blindadas a medida en Santiago de Chile. Más de 20 años de experiencia entregando calidad.
        </p>
      </div>

      <!-- Links -->
      <div class="footer__col">
        <h4 class="footer__col-title">Navegación</h4>
        <ul class="footer__links">
          <li><a href="/">Inicio</a></li>
          <li><a href="#servicios">Nuestros Servicios</a></li>
          <li><a href="#por-que-elegirnos">Por Qué Elegirnos</a></li>
          <li><a href="#proceso">Cómo Trabajamos</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="footer__col">
        <h4 class="footer__col-title">Servicios</h4>
        <ul class="footer__links">
          <li><a href="#servicios">Puertas Enchapadas</a></li>
          <li><a href="#servicios">Puertas Blindadas</a></li>
          <li><a href="#servicios">Restauración y Barnizado</a></li>
          <li><a href="#servicios">Fabricación a Medida</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer__col">
        <h4 class="footer__col-title">Contacto</h4>
        <ul class="footer__contact">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            <a href="tel:+56957290061">+56 9 5729 0061</a>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <a href="mailto:contacto@puertasvalencia.cl">contacto@puertasvalencia.cl</a>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <span>Lampa, Santiago</span>
          </li>
        </ul>
        <a
          href="https://wa.me/56957290061"
          target="_blank"
          rel="noopener"
          class="footer__wa cta-btn--metallic"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Chatear por WhatsApp
        </a>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>© {year} Puertas Valencia. Todos los derechos reservados.</p>
      <p class="footer__location">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
        </svg>
        Lampa, Santiago de Chile
      </p>
    </div>
  </div>
</footer>

<style>
  :root {
    --f-gold: #c8a84b;
    --f-gold-light: #e8c96a;
    --f-gold-dark: #96791f;
  }

  .footer {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
    color: rgba(255, 255, 255, 0.65);
    position: relative;
    border-top: 2px solid rgba(200, 168, 75, 0.4);
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--f-gold-light), transparent);
  }

  .footer__main {
    padding: 72px 0 56px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
    gap: 56px;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
  }

  .footer__desc {
    font-size: 14px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 24px;
  }

  .footer__social {
    display: flex;
    gap: 12px;
  }

  .social-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #222 0%, #111 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.3s ease;
  }

  .social-btn:hover {
    background: linear-gradient(135deg, var(--f-gold-dark) 0%, var(--f-gold) 100%);
    border-color: var(--f-gold-light);
    color: #111;
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(200, 168, 75, 0.25);
  }

  .footer__col-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: 24px;
    position: relative;
    padding-bottom: 12px;
  }

  .footer__col-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, var(--f-gold), transparent);
  }

  .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    transition: all 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .footer__links a::before {
    content: '›';
    color: var(--f-gold);
    font-size: 18px;
    line-height: 0;
    transition: transform 0.2s ease;
  }

  .footer__links a:hover {
    color: var(--f-gold-light);
  }

  .footer__links a:hover::before {
    transform: translateX(4px);
  }

  .footer__contact {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
  }

  .footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
  }

  .footer__contact svg {
    color: var(--f-gold);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer__contact a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .footer__contact a:hover {
    color: var(--f-gold-light);
  }

  .cta-btn--metallic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 20px;
    background: linear-gradient(135deg, #1a1a1a 0%, #3d3d3d 50%, #1a1a1a 100%);
    color: #f0eede;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 6px;
    border: 1px solid rgba(200, 168, 75, 0.3);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07), 0 4px 18px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .cta-btn--metallic::before {
    content: '';
    position: absolute;
    top: 0;
    left: -80%;
    width: 60%;
    height: 100%;
    background: linear-gradient(120deg, transparent, rgba(200, 168, 75, 0.2), transparent);
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .cta-btn--metallic > * {
    position: relative;
    z-index: 1;
  }

  .cta-btn--metallic:hover::before {
    left: 130%;
  }

  .cta-btn--metallic:hover {
    background: linear-gradient(135deg, #2c2c2c 0%, #555 50%, #2c2c2c 100%);
    border-color: rgba(200, 168, 75, 0.6);
    transform: translateY(-2px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1), 0 8px 24px rgba(0, 0, 0, 0.2);
    color: var(--f-gold-light);
  }

  .footer__bottom {
    padding: 24px 0;
    background: #050505;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer__location {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__location svg {
    color: var(--f-gold);
  }

  @media (max-width: 1000px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
    .footer__brand {
      grid-column: 1 / -1;
      max-width: 600px;
    }
  }

  @media (max-width: 600px) {
    .footer__main {
      padding: 56px 0 40px;
    }
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer__bottom-inner {
      flex-direction: column;
      text-align: center;
      gap: 12px;
    }
  }
</style>
