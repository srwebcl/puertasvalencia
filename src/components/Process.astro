---
const steps = [
  {
    num: '01',
    title: 'Solicitud y Cotización',
    desc: 'Contáctanos por WhatsApp, teléfono o formulario. Cuéntanos qué necesitas y te enviamos un presupuesto personalizado rápidamente.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
  },
  {
    num: '02',
    title: 'Evaluación y Medida',
    desc: 'Coordinamos una visita técnica o te guiamos para tomar las medidas. Analizamos el espacio y tus preferencias de diseño.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 3H3v7l9 11 9-11V3z"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    num: '03',
    title: 'Fabricación a Medida',
    desc: 'En nuestro taller fabricamos tu puerta con las mejores maderas y materiales, según las especificaciones acordadas.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M5.34 17.66l-1.41 1.41M2 12h2M20 12h2M17.66 17.66l1.41 1.41M6.34 6.34L4.93 4.93M12 2v2M12 20v2"/></svg>`,
  },
  {
    num: '04',
    title: 'Instalación Profesional',
    desc: 'Nuestro equipo instala tu puerta con precisión, asegurándose de que quede perfectamente nivelada y con excelente acabado.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    num: '05',
    title: 'Entrega y Revisión',
    desc: 'Verificamos el funcionamiento perfecto, te explicamos el mantenimiento y garantizamos tu satisfacción total.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>`,
  },
];
---

<section class="process" id="proceso" aria-labelledby="process-title">
  <!-- Fondo con textura sutil -->
  <div class="process__bg" aria-hidden="true"></div>

  <div class="container">
    <div class="section-header" data-animate>
      <span class="section-tag light">Nuestro Proceso</span>
      <h2 class="section-title light" id="process-title">
        ¿Cómo Trabajamos?
      </h2>
      <p class="section-subtitle light">
        Un proceso claro, rápido y acompañado desde la primera consulta hasta la instalación final.
      </p>
    </div>

    <!-- Timeline horizontal / vertical en movil -->
    <div class="process__steps">
      {steps.map((step, i) => (
        <div class="process__step" data-animate style={`animation-delay: ${i * 0.12}s`}>
          <!-- Conector entre pasos -->
          <div class="step__connector" aria-hidden="true">
            {i < steps.length - 1 && <span class="connector-line"></span>}
          </div>
          
          <div class="step__num">{step.num}</div>
          
          <div class="step__body">
            <div class="step__icon">
              <Fragment set:html={step.icon} />
            </div>
            <h3 class="step__title">{step.title}</h3>
            <p class="step__desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="process__cta" data-animate>
      <p>¿Listo para comenzar? Solicita tu evaluación gratuita hoy.</p>
      <a href="#contacto" class="cta-btn cta-btn--metallic">
        Solicitar Cotización Gratuita
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Variables de paleta ──────────────────────────────── */
  :root {
    --p-gold:        #c8a84b;
    --p-gold-light:  #e8c96a;
    --p-gold-dark:   #96791f;
    --p-metal-dark:  #111111;
    --p-metal-mid:   #2a2a2a;
    --p-metal-light: #444444;
  }

  .process {
    padding: 72px 0;
    position: relative;
    overflow: hidden;
  }

  /* Fondo oscuro con imagen de fondo */
  .process__bg {
    position: absolute;
    inset: 0;
    background-image: url('/web_images/La_misma_imagen_pero_que_202605142038.jpeg');
    background-size: cover;
    background-position: center;
  }

  /* Overlay negro casi opaco para mantener legibilidad y elegancia */
  .process__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(17,17,17,0.94) 0%, rgba(28,28,28,0.88) 50%, rgba(17,17,17,0.96) 100%);
    z-index: 1;
  }

  /* Brillos dorados y plateados muy sutiles sobre el overlay */
  .process__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 15% 70%, rgba(200,168,75,0.08) 0%, transparent 40%),
      radial-gradient(circle at 85% 30%, rgba(255,255,255,0.04) 0%, transparent 40%);
    pointer-events: none;
    z-index: 2;
  }

  /* Borde superior dorado */
  .process::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--p-metal-dark), var(--p-gold-dark), var(--p-gold), var(--p-gold-light), var(--p-gold), var(--p-gold-dark), var(--p-metal-dark));
    z-index: 10;
  }

  .container { position: relative; z-index: 2; }

  /* ── Encabezado ─────────────────────────────────────── */
  .section-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 64px;
  }

  .section-tag.light {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--p-gold-light);
    border: 1px solid rgba(200,168,75,0.4);
    background: rgba(200,168,75,0.08);
    padding: 5px 16px;
    border-radius: 2px;
    margin-bottom: 16px;
  }

  .section-title.light {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .section-subtitle.light {
    color: rgba(255,255,255,0.65);
    font-size: 16px;
    line-height: 1.7;
  }

  /* ── Timeline Steps ─────────────────────────────────── */
  .process__steps {
    display: flex;
    gap: 0;
    position: relative;
    margin-bottom: 72px;
    overflow-x: auto;
    padding: 20px 0 10px;
    scrollbar-width: none; /* Firefox */
  }
  
  .process__steps::-webkit-scrollbar { display: none; } /* Chrome/Safari */

  .process__step {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    gap: 20px;
  }

  /* El número dorado */
  .step__num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 15px;
    letter-spacing: 0.1em;
    color: #111;
    background: linear-gradient(135deg, var(--p-gold-dark) 0%, var(--p-gold) 50%, var(--p-gold-light) 100%);
    box-shadow: 0 4px 12px rgba(200,168,75,0.2), inset 0 1px 0 rgba(255,255,255,0.4);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .process__step:hover .step__num {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(200,168,75,0.4), inset 0 1px 0 rgba(255,255,255,0.5);
  }

  /* Línea conectora horizontal */
  .step__connector {
    position: absolute;
    top: 24px;
    left: 50%;
    right: -50%;
    z-index: 1;
    pointer-events: none;
  }

  .connector-line {
    display: block;
    height: 2px;
    background: linear-gradient(90deg, rgba(200,168,75,0.6), rgba(200,168,75,0.1));
    width: 100%;
  }

  /* Contenido del paso */
  .step__body {
    text-align: center;
    padding: 0 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    padding-top: 24px;
    padding-bottom: 24px;
    height: 100%;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .process__step:hover .step__body {
    background: rgba(255,255,255,0.06);
    border-color: rgba(200,168,75,0.3);
  }

  .step__icon {
    color: var(--p-gold);
    margin-bottom: 16px;
    display: flex;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .process__step:hover .step__icon { 
    opacity: 1; 
    transform: translateY(-3px);
  }

  .step__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 10px;
    line-height: 1.3;
    letter-spacing: 0.02em;
  }

  .step__desc {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
  }

  /* ── CTA Final ──────────────────────────────────────── */
  .process__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .process__cta p {
    color: rgba(255,255,255,0.7);
    font-size: 15px;
  }

  /* Botón Metálico Claro (Plata) */
  .cta-btn--metallic {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #e6e6e6 0%, #ffffff 50%, #d4d4d4 100%);
    color: #111;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: var(--radius);
    transition: all 0.3s ease;
    border: 1px solid #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  /* Shimmer dorado sutil en botón claro */
  .cta-btn--metallic::before {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(200,168,75,0.4), transparent);
    transition: left 0.6s ease;
  }

  .cta-btn--metallic:hover::before { left: 150%; }

  .cta-btn--metallic:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(200,168,75,0.25);
    border-color: var(--p-gold);
    color: #000;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .process__steps {
      flex-direction: column;
      overflow-x: visible;
      gap: 24px;
    }

    .process__step {
      flex-direction: row;
      align-items: flex-start;
      min-width: unset;
      gap: 24px;
    }

    .step__connector {
      top: 48px;
      left: 23px; /* Centrado respecto al número de 48px */
      right: auto;
      bottom: -24px; /* Hasta el siguiente paso */
      height: auto;
      width: 2px;
    }

    .connector-line {
      width: 2px;
      height: 100%;
      background: linear-gradient(180deg, rgba(200,168,75,0.6), rgba(200,168,75,0.1));
    }

    .step__body { 
      text-align: left; 
      margin-bottom: 0;
      flex: 1;
      padding: 20px;
    }
    
    .step__icon { justify-content: flex-start; }
    
    /* Ocultar el último conector vertical */
    .process__step:last-child .step__connector { display: none; }
  }

  @media (max-width: 480px) {
    .process { padding: 56px 0; }
    .process__step { gap: 16px; }
    .step__connector { left: 23px; }
    .step__num { width: 40px; height: 40px; font-size: 13px; }
    .step__connector { left: 19px; } /* Recalcular por tamaño menor */
    .cta-btn--metallic { padding: 14px 20px; font-size: 13px; width: 100%; justify-content: center; }
  }
</style>
